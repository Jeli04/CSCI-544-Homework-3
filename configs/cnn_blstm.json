{
    "data": {
        "train_dir": "data/train",
        "dev_dir": "data/dev",
        "test_dir": "data/test"
    },
    "model": {
        "char_vocab_size": 100,
        "char_embed_size": 30,
        "num_filters": 30,
        "kernel_size": 3,
        "word_vocab_size": 100,
        "word_embed_size": 100,
        "embed_size": 130,
        "hidden_size": 200,
        "output_size": 128,
        "num_classes": 9,
        "num_layers": 1,
        "num_cnn_layers": 1,
        "dropout": 0.5,
        "case_embed_size": 5
    },
    "training": {
        "batch_size": 10,
        "epochs": 35,
        "lr": 0.015,
        "momentum": 0.9,
        "val_iter": 2,
        "optimizer": "sgd",
        "use_glove": true,
        "lr_factor": 0.0,
        "rho": 0.05
    }
